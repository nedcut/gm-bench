{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gm-bench.dev/schemas/gm_action_list.schema.json",
  "title": "GM-Bench Action List v2",
  "description": "JSON array written to stdout by external agents (stdin/stdout protocol).",
  "type": "array",
  "maxItems": 24,
  "items": { "$ref": "#/$defs/action" },
  "$defs": {
    "action": {
      "type": "object",
      "additionalProperties": true,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "sign_free_agent",
            "release",
            "trade",
            "draft",
            "set_lineup",
            "memo",
            "noop",
            "inspect_team",
            "inspect_player",
            "list_free_agents",
            "scout",
            "accept_trade_offer",
            "reject_trade_offer",
            "counter_trade_offer",
            "claim_waiver",
            "end_turn"
          ]
        },
        "player_id": { "type": "integer" },
        "player_ids": { "type": "array", "items": { "type": "integer" } },
        "prospect_id": { "type": "integer" },
        "partner_team_id": { "type": "integer" },
        "team_id": { "type": "integer" },
        "offer_id": { "type": "string" },
        "give_player_ids": { "type": "array", "items": { "type": "integer" } },
        "receive_player_ids": { "type": "array", "items": { "type": "integer" } },
        "give_pick_seasons": { "type": "array", "items": { "type": "integer" } },
        "receive_pick_seasons": { "type": "array", "items": { "type": "integer" } },
        "position": { "type": "string", "enum": ["F", "D", "G"] },
        "min_overall": { "type": "number" },
        "limit": { "type": "integer" },
        "years": { "type": "integer", "minimum": 1, "maximum": 5 },
        "salary": { "type": "number", "minimum": 0 },
        "text": { "type": "string", "maxLength": 2000 },
        "error": { "type": "string" }
      }
    }
  }
}
