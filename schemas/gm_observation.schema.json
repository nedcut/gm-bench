{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gm-bench.dev/schemas/gm_observation.schema.json",
  "title": "GM-Bench Observation v2",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "benchmark",
    "seed",
    "season",
    "phase",
    "observation_tier",
    "rules",
    "team",
    "standings",
    "draft_order",
    "history",
    "recent_transactions",
    "memo",
    "scouting_budget",
    "incoming_trade_offers",
    "available_actions"
  ],
  "properties": {
    "benchmark": { "type": "string" },
    "seed": { "type": "integer" },
    "season": { "type": "integer", "minimum": 1 },
    "phase": {
      "type": "string",
      "enum": ["preseason", "midseason", "trade_deadline", "draft"]
    },
    "observation_tier": { "type": "string", "enum": ["summary", "full"] },
    "interaction_round": { "type": "integer", "minimum": 0 },
    "action_results": { "type": "array" },
    "rules": { "type": "object" },
    "team": { "type": "object" },
    "standings": { "type": "array" },
    "free_agents": { "type": "array" },
    "free_agents_summary": { "type": "object" },
    "draft_class": { "type": "array" },
    "draft_class_summary": { "type": "object" },
    "draft_order": { "type": "array" },
    "trade_market": { "type": "array" },
    "trade_market_summary": { "type": "object" },
    "waiver_wire": { "type": "array" },
    "waiver_wire_summary": { "type": "object" },
    "history": { "type": "array" },
    "recent_transactions": { "type": "array" },
    "memo": { "type": "string" },
    "scouting_budget": { "type": "object" },
    "incoming_trade_offers": { "type": "array" },
    "available_actions": { "type": "array", "items": { "type": "string" } },
    "hint": { "type": "string" }
  }
}
