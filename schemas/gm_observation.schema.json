{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gm-bench.dev/schemas/gm_observation.schema.json",
  "title": "GM-Bench Observation",
  "description": "Observation payload sent to agents at each decision point.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "benchmark",
    "seed",
    "season",
    "phase",
    "rules",
    "team",
    "standings",
    "free_agents",
    "draft_class",
    "draft_order",
    "trade_market",
    "history",
    "recent_transactions",
    "memo"
  ],
  "properties": {
    "benchmark": { "type": "string", "const": "gm-bench-mvp" },
    "seed": { "type": "integer" },
    "season": { "type": "integer", "minimum": 1 },
    "phase": { "type": "string", "enum": ["preseason", "trade_deadline", "draft"] },
    "rules": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "salary_cap",
        "hard_cap_buffer",
        "roster_min",
        "lineup_size",
        "lineup_min_positions",
        "trade_value_threshold",
        "trade_limit_per_partner",
        "fa_reservation_range",
        "rejected_offer_limit_per_window",
        "pick_trading"
      ],
      "properties": {
        "salary_cap": { "type": "number" },
        "hard_cap_buffer": { "type": "number", "minimum": 0 },
        "roster_min": { "type": "integer", "minimum": 1 },
        "lineup_size": { "type": "integer", "minimum": 1 },
        "lineup_min_positions": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "F": { "type": "integer", "minimum": 0 },
            "D": { "type": "integer", "minimum": 0 },
            "G": { "type": "integer", "minimum": 0 }
          }
        },
        "trade_value_threshold": { "type": "number", "minimum": 0, "maximum": 1 },
        "trade_limit_per_partner": { "type": "integer", "minimum": 0 },
        "fa_reservation_range": {
          "type": "array",
          "items": { "type": "number", "minimum": 0 },
          "minItems": 2,
          "maxItems": 2
        },
        "rejected_offer_limit_per_window": { "type": "integer", "minimum": 1 },
        "scouting": {
          "type": "object",
          "additionalProperties": false,
          "required": ["points_per_season", "points_remaining", "report_noise"],
          "properties": {
            "points_per_season": { "type": "integer", "minimum": 0 },
            "points_remaining": { "type": "integer", "minimum": 0 },
            "report_noise": { "type": "number", "minimum": 0 }
          }
        },
        "pick_trading": {
          "type": "object",
          "additionalProperties": false,
          "required": ["max_seasons_ahead", "pick_value_estimate"],
          "properties": {
            "max_seasons_ahead": { "type": "integer", "minimum": 0 },
            "pick_value_estimate": {
              "description": "Rough asset value of a pick per tradeable future season, keyed by season number.",
              "type": "object",
              "additionalProperties": { "type": "number", "minimum": 0 }
            }
          }
        }
      }
    },
    "team": { "$ref": "#/$defs/team" },
    "standings": {
      "type": "array",
      "items": { "$ref": "#/$defs/standing" }
    },
    "free_agents": {
      "type": "array",
      "items": { "$ref": "#/$defs/free_agent" }
    },
    "draft_class": {
      "type": "array",
      "items": { "$ref": "#/$defs/player" }
    },
    "draft_order": {
      "description": "Team ids with a current-season pick remaining, in pick order (worst record first).",
      "type": "array",
      "items": { "type": "integer" }
    },
    "trade_market": {
      "type": "array",
      "items": { "$ref": "#/$defs/trade_offer" }
    },
    "incoming_offers": {
      "description": "Opponent-initiated trade offers, valid only for this decision point.",
      "type": "array",
      "items": { "$ref": "#/$defs/incoming_offer" }
    },
    "scout_reports": {
      "description": "Near-true potential estimates from past scout actions, keyed by player id. Persist across seasons.",
      "type": "object",
      "additionalProperties": { "type": "number" }
    },
    "history": {
      "type": "array",
      "items": { "$ref": "#/$defs/season_summary" }
    },
    "recent_transactions": {
      "type": "array",
      "items": { "$ref": "#/$defs/transaction" }
    },
    "memo": {
      "description": "The agent's own persistent scratchpad, set via the memo action and echoed back at every decision point.",
      "type": "string",
      "maxLength": 2000
    }
  },
  "$defs": {
    "player": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "position",
        "age",
        "overall",
        "potential",
        "salary",
        "contract_years",
        "injury_risk",
        "morale"
      ],
      "properties": {
        "id": { "type": "integer" },
        "name": { "type": "string" },
        "position": { "type": "string", "enum": ["F", "D", "G"] },
        "age": { "type": "integer", "minimum": 16 },
        "overall": { "type": "number" },
        "potential": { "type": "number" },
        "salary": { "type": "number", "minimum": 0 },
        "contract_years": { "type": "integer", "minimum": 0 },
        "injury_risk": { "type": "number", "minimum": 0, "maximum": 1 },
        "morale": { "type": "number" }
      }
    },
    "free_agent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "position",
        "age",
        "overall",
        "potential",
        "salary",
        "contract_years",
        "injury_risk",
        "morale",
        "asking_salary"
      ],
      "properties": {
        "id": { "type": "integer" },
        "name": { "type": "string" },
        "position": { "type": "string", "enum": ["F", "D", "G"] },
        "age": { "type": "integer", "minimum": 16 },
        "overall": { "type": "number" },
        "potential": { "type": "number" },
        "salary": { "type": "number", "minimum": 0 },
        "contract_years": { "type": "integer", "minimum": 0 },
        "injury_risk": { "type": "number", "minimum": 0, "maximum": 1 },
        "morale": { "type": "number" },
        "asking_salary": { "type": "number", "minimum": 0 }
      }
    },
    "team": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "market",
        "patience",
        "wins",
        "losses",
        "championships",
        "playoff_rounds",
        "payroll",
        "cap_room",
        "draft_picks",
        "lineup",
        "roster"
      ],
      "properties": {
        "id": { "type": "integer" },
        "name": { "type": "string" },
        "market": { "type": "number" },
        "patience": { "type": "number" },
        "wins": { "type": "integer", "minimum": 0 },
        "losses": { "type": "integer", "minimum": 0 },
        "championships": { "type": "integer", "minimum": 0 },
        "playoff_rounds": { "type": "integer", "minimum": 0 },
        "payroll": { "type": "number", "minimum": 0 },
        "cap_room": { "type": "number" },
        "draft_picks": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "lineup": {
          "description": "Player ids most recently set via set_lineup; empty until first set. Stale entries are repaired at simulation time.",
          "type": "array",
          "items": { "type": "integer" }
        },
        "roster": {
          "type": "array",
          "items": { "$ref": "#/$defs/player" }
        }
      }
    },
    "standing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["team_id", "team_name", "wins", "losses", "championships", "public_strength", "draft_picks"],
      "properties": {
        "team_id": { "type": "integer" },
        "team_name": { "type": "string" },
        "wins": { "type": "integer", "minimum": 0 },
        "losses": { "type": "integer", "minimum": 0 },
        "championships": { "type": "integer", "minimum": 0 },
        "public_strength": { "type": "number" },
        "draft_picks": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "incoming_offer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "offer_id",
        "team_id",
        "team_name",
        "you_receive_players",
        "they_receive_players",
        "you_receive_pick_seasons",
        "they_receive_pick_seasons",
        "expires"
      ],
      "properties": {
        "offer_id": { "type": "string" },
        "team_id": { "type": "integer" },
        "team_name": { "type": "string" },
        "you_receive_players": { "type": "array", "items": { "$ref": "#/$defs/player" } },
        "they_receive_players": { "type": "array", "items": { "$ref": "#/$defs/player" } },
        "you_receive_pick_seasons": { "type": "array", "items": { "type": "integer" } },
        "they_receive_pick_seasons": { "type": "array", "items": { "type": "integer" } },
        "expires": { "type": "string" }
      }
    },
    "trade_offer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["team_id", "team_name", "player", "estimated_price"],
      "properties": {
        "team_id": { "type": "integer" },
        "team_name": { "type": "string" },
        "player": { "$ref": "#/$defs/player" },
        "estimated_price": { "type": "number", "minimum": 0 }
      }
    },
    "season_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "season",
        "wins",
        "losses",
        "payroll",
        "cap_room",
        "champion_team_id",
        "playoff_rounds",
        "score_after_season"
      ],
      "properties": {
        "season": { "type": "integer", "minimum": 1 },
        "wins": { "type": "integer", "minimum": 0 },
        "losses": { "type": "integer", "minimum": 0 },
        "payroll": { "type": "number", "minimum": 0 },
        "cap_room": { "type": "number" },
        "champion_team_id": { "type": "integer" },
        "playoff_rounds": { "type": "integer", "minimum": 0 },
        "score_after_season": { "type": "number" }
      }
    },
    "transaction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["season", "phase", "team_id", "action", "accepted", "message"],
      "properties": {
        "season": { "type": "integer", "minimum": 1 },
        "phase": { "type": "string" },
        "team_id": { "type": "integer" },
        "action": { "type": "object" },
        "accepted": { "type": "boolean" },
        "message": { "type": "string" }
      }
    }
  }
}
