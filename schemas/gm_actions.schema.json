{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["actions"],
  "properties": {
    "actions": {
      "type": "array",
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type",
          "player_id",
          "player_ids",
          "prospect_id",
          "partner_team_id",
          "give_player_ids",
          "receive_player_ids",
          "give_pick_seasons",
          "receive_pick_seasons",
          "offer_id",
          "years",
          "salary",
          "text"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["sign_free_agent", "extend_contract", "release", "trade", "accept_offer", "decline_offer", "scout", "draft", "set_lineup", "memo", "noop"]
          },
          "player_id": { "type": ["integer", "null"] },
          "player_ids": {
            "type": ["array", "null"],
            "items": { "type": "integer" }
          },
          "prospect_id": { "type": ["integer", "null"] },
          "partner_team_id": { "type": ["integer", "null"] },
          "give_player_ids": {
            "type": ["array", "null"],
            "items": { "type": "integer" }
          },
          "receive_player_ids": {
            "type": ["array", "null"],
            "items": { "type": "integer" }
          },
          "give_pick_seasons": {
            "type": ["array", "null"],
            "items": { "type": "integer" }
          },
          "receive_pick_seasons": {
            "type": ["array", "null"],
            "items": { "type": "integer" }
          },
          "offer_id": { "type": ["string", "null"] },
          "years": { "type": ["integer", "null"], "minimum": 1, "maximum": 5 },
          "salary": { "type": ["number", "null"], "minimum": 0 },
          "text": { "type": ["string", "null"], "maxLength": 2000 }
        }
      }
    }
  }
}
